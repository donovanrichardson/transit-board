GTFS_URL=https://example.com/path/to/gtfs.zip
JDBC_URL=jdbc:mysql://oba_database:3306/oba_database
JDBC_USER=oba
JDBC_PASSWORD=
# export JDBC_PASSWORD=<your-db-password>
# MYSQL_ROOT_PASSWORD is required. Export it from pass before running docker compose:
#   export MYSQL_ROOT_PASSWORD=<your-mysql-root-password>
MYSQL_ROOT_PASSWORD=
# export OBA_API_KEY=<your-oba-api-key>
OBA_API_KEY=
